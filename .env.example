# Copy to .env.local and fill in values (never commit .env.local)

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Bunny Stream — server-side only (admin video upload)
# Dashboard: Stream → your library → API → Library ID + API key
BUNNY_STREAM_LIBRARY_ID=
BUNNY_STREAM_API_KEY=

# Bunny Stream CDN hostname (playback + thumbnails — public, client-safe)
# Example: vz-f7a686f2-d74.b-cdn.net (from Stream → your video → embed / CDN hostname)
NEXT_PUBLIC_BUNNY_STREAM_CDN_HOST=
